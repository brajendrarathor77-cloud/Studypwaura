const fetch = require('node-fetch');
export default async function handler(req, res) {
    const targetUrl = `http://deltastudy.site${req.url}`;
    const response = await fetch(targetUrl);
    let data = await response.text();

    // 1. Key Bypass (hidden true ko false karega)
    data = data.replace(/"hidden":true/g, '"hidden":false'); 

    // 2. Name Change
    data = data.replace(/Delta Study/g, 'StudyPW Aura'); 

    res.setHeader('Content-Type', 'text/html');
    res.send(data);
}
